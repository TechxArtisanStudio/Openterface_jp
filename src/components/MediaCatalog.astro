---
import { mediaCatalog } from '../data/mediaCatalog';
import { siteConfig } from '../config/site';
import { getMediaStrings } from '../i18n/media';
import {
  APP_DISPLAY_NAMES,
  KNOWN_APPS,
  KNOWN_PRODUCTS,
  LANGUAGE_DISPLAY_NAMES,
  PRODUCT_DISPLAY_NAMES,
  productDisplayName,
  languageDisplayName,
  type MediaCatalogEntry,
} from '../lib/youtube';

const strings = getMediaStrings(siteConfig.locale);
const locale = siteConfig.locale;

const languages = new Set(mediaCatalog.map((e) => e.language).filter(Boolean));
const products = new Set(mediaCatalog.map((e) => e.product).filter(Boolean));

const formatFilters: { value: string; label: string }[] = [
  { value: '', label: strings.formatAll },
  { value: 'long', label: strings.formatVideos },
  { value: 'short', label: strings.formatShorts },
  { value: 'post', label: strings.formatPosts },
  { value: 'testimonial', label: strings.formatTestimonials },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: strings.title,
  numberOfItems: mediaCatalog.length,
  itemListElement: mediaCatalog.slice(0, 20).map((entry, i) => {
    if (entry.format === 'long' || entry.format === 'short') {
      return {
        '@type': 'ListItem',
        position: i + 1,
        item: {
          '@type': 'VideoObject',
          name: entry.title,
          url: entry.url,
          thumbnailUrl: entry.thumbnail,
          uploadDate: entry.date || undefined,
          author: { '@type': 'Person', name: entry.author },
        },
      };
    }
    return {
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'SocialMediaPosting',
        headline: entry.title,
        url: entry.externalUrl,
        datePublished: entry.date || undefined,
        author: { '@type': 'Person', name: entry.author },
      },
    };
  }),
};

const catalogConfig = {
  locale,
  knownProducts: [...KNOWN_PRODUCTS],
  knownApps: [...KNOWN_APPS],
  productLabels: PRODUCT_DISPLAY_NAMES,
  appLabels: APP_DISPLAY_NAMES,
  languageLabels: LANGUAGE_DISPLAY_NAMES,
  viewsLabel: strings.views,
  emptyResults: strings.emptyResults,
  sampleBadge: strings.sampleBadge,
  readOriginal: strings.readOriginal,
  platformLabels: {
    x: strings.platformX,
    threads: strings.platformThreads,
    instagram: strings.platformInstagram,
  },
};

function platformLabel(entry: MediaCatalogEntry): string {
  if (!entry.platform) return 'Social';
  return catalogConfig.platformLabels[entry.platform] ?? entry.platform;
}

const isVideo = (entry: MediaCatalogEntry) => entry.format === 'long' || entry.format === 'short';
---

<section class="media-catalog bg-surface pb-16 pt-10 md:pb-20 md:pt-12" aria-labelledby="media-catalog-title">
  <div class="mx-auto max-w-6xl px-4">
    <header class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-accent-on-light">Openterface</p>
      <h1 id="media-catalog-title" class="section-title mt-2">{strings.title}</h1>
      <p class="section-subtitle">{strings.subtitle}</p>
    </header>

    <div
      class="mt-6 flex flex-wrap justify-center gap-2"
      role="group"
      aria-label={strings.formatChipsAria}
    >
      {
        formatFilters.map((chip) => (
          <button
            type="button"
            class="media-format-chip"
            data-format-chip={chip.value}
            aria-pressed={chip.value === '' ? 'true' : 'false'}
            class:list={[chip.value === '' && 'media-format-chip--active']}
          >
            {chip.label}
          </button>
        ))
      }
    </div>

    <div class="media-catalog-toolbar mt-8 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm md:p-5">
      <div class="flex flex-wrap gap-2 md:gap-3">
        <div class="inline-flex items-baseline gap-1.5 rounded-full border border-gray-200 bg-surface px-3 py-1.5 text-sm">
          <span class="font-bold text-ink" data-stat-total>{mediaCatalog.length}</span>
          <span class="text-muted">{strings.totalItems}</span>
        </div>
        <div class="inline-flex items-baseline gap-1.5 rounded-full border border-gray-200 bg-surface px-3 py-1.5 text-sm">
          <span class="font-bold text-ink" data-stat-languages>{languages.size}</span>
          <span class="text-muted">{strings.languages}</span>
        </div>
        <div class="inline-flex items-baseline gap-1.5 rounded-full border border-gray-200 bg-surface px-3 py-1.5 text-sm">
          <span class="font-bold text-ink" data-stat-products>{products.size}</span>
          <span class="text-muted">{strings.products}</span>
        </div>
      </div>

      <div
        class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-5 lg:items-end"
        role="region"
        aria-label={strings.controlsAria}
      >
        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-semibold text-ink">{strings.sortBy}</span>
          <select data-sort class="media-catalog-select">
            <option value="newest">{strings.sortNewest}</option>
            <option value="oldest">{strings.sortOldest}</option>
            <option value="views">{strings.sortMostViews}</option>
          </select>
        </label>

        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-semibold text-ink">{strings.filterProduct}</span>
          <select data-filter-product class="media-catalog-select">
            <option value="">{strings.allProducts}</option>
          </select>
        </label>

        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-semibold text-ink">{strings.filterApp}</span>
          <select data-filter-app class="media-catalog-select">
            <option value="">{strings.allApps}</option>
          </select>
        </label>

        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-semibold text-ink">{strings.filterLanguage}</span>
          <select data-filter-language class="media-catalog-select">
            <option value="">{strings.allLanguages}</option>
          </select>
        </label>

        <p class="text-sm text-muted sm:col-span-2 lg:col-span-1 lg:text-right" aria-live="polite">
          {strings.showing}
          <strong class="text-ink"><span data-results-visible>{mediaCatalog.length}</span></strong>
          /
          <span data-results-total>{mediaCatalog.length}</span>
        </p>
      </div>
    </div>

    <p class="media-catalog-empty mt-8 text-center text-muted" data-empty-state hidden>
      {strings.emptyResults}
    </p>

    <div class="media-catalog-grid mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3" data-media-grid>
      {
        mediaCatalog.map((entry) =>
          isVideo(entry) ? (
            <article
              class="media-catalog-card media-catalog-card--video group"
              data-entry-id={entry.id}
              data-format={entry.format}
              data-date={entry.date}
              data-views={entry.views ?? 0}
              data-product={entry.product ?? ''}
              data-language={entry.language ?? ''}
              data-app={entry.app ?? ''}
            >
              <a href={entry.url} target="_blank" rel="noopener noreferrer" class="block h-full">
                <div
                  class:list={[
                    'media-catalog-thumb relative overflow-hidden rounded-xl bg-gray-200 shadow-sm ring-1 ring-black/5 transition duration-300 group-hover:-translate-y-0.5 group-hover:shadow-md group-hover:ring-primary-dark/30',
                    entry.format === 'short' ? 'aspect-[9/16] max-h-80 mx-auto' : 'aspect-video',
                  ]}
                >
                  <img
                    src={entry.thumbnail}
                    alt={entry.title}
                    width={480}
                    height={270}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                  <span
                    class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/0 transition group-hover:bg-black/15"
                    aria-hidden="true"
                  >
                    <span
                      class="flex h-11 w-11 scale-90 items-center justify-center rounded-full bg-black/65 text-white opacity-0 shadow-lg transition group-hover:scale-100 group-hover:opacity-100"
                    >
                      <svg class="ml-0.5 h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </span>
                  </span>
                </div>
                <div class="mt-3 flex flex-col gap-2">
                  <h2 class="line-clamp-2 text-base font-semibold leading-snug text-ink group-hover:text-primary-dark">
                    {entry.title}
                  </h2>
                  {
                    entry.product || entry.language || entry.app ? (
                      <div class="flex flex-wrap gap-1.5">
                        {
                          entry.product ? (
                            <span class="media-catalog-tag media-catalog-tag--product">
                              {productDisplayName(entry.product)}
                            </span>
                          ) : null
                        }
                        {
                          entry.app ? (
                            <span class="media-catalog-tag media-catalog-tag--app">
                              {APP_DISPLAY_NAMES[entry.app]}
                            </span>
                          ) : null
                        }
                        {
                          entry.language ? (
                            <span class="media-catalog-tag media-catalog-tag--lang">
                              {languageDisplayName(entry.language)}
                            </span>
                          ) : null
                        }
                      </div>
                    ) : null
                  }
                  <div class="flex items-center gap-2">
                    {
                      entry.channelAvatar ? (
                        <img
                          src={entry.channelAvatar}
                          alt=""
                          width={22}
                          height={22}
                          class="h-[22px] w-[22px] shrink-0 rounded-full bg-gray-100 object-cover ring-1 ring-gray-200/80"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : null
                    }
                    <span class="min-w-0 truncate text-sm text-muted">{entry.author}</span>
                  </div>
                  <p class="text-xs text-muted/90">
                    {entry.viewsFormatted} {strings.views}
                    {entry.date ? ` · ${entry.date}` : ''}
                  </p>
                </div>
              </a>
            </article>
          ) : (
            <article
              class="media-catalog-card media-catalog-card--post group"
              data-entry-id={entry.id}
              data-format={entry.format}
              data-date={entry.date}
              data-product={entry.product ?? ''}
              data-language={entry.language ?? ''}
              data-app={entry.app ?? ''}
            >
              <a
                href={entry.externalUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="card block h-full hover:border-primary-dark hover:shadow-md"
              >
                <div class="flex items-start justify-between gap-2">
                  <span class="text-xs font-bold uppercase tracking-wide text-muted">{platformLabel(entry)}</span>
                  {entry.sample ? (
                    <span class="media-catalog-tag media-catalog-tag--sample">{strings.sampleBadge}</span>
                  ) : null}
                </div>
                <h2 class="mt-3 line-clamp-2 text-base font-semibold leading-snug text-ink group-hover:text-primary-dark">
                  {entry.title}
                </h2>
                <p class="mt-2 line-clamp-3 text-sm text-muted">{entry.excerpt}</p>
                {
                  entry.product ? (
                    <div class="mt-3 flex flex-wrap gap-1.5">
                      <span class="media-catalog-tag media-catalog-tag--product">
                        {productDisplayName(entry.product)}
                      </span>
                    </div>
                  ) : null
                }
                <p class="mt-3 text-sm text-muted">
                  {entry.author}
                  {entry.date ? ` · ${entry.date}` : ''}
                </p>
                <p class="mt-3 text-sm font-semibold text-primary-dark">{strings.readOriginal}</p>
              </a>
            </article>
          ),
        )
      }
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</section>

<script type="application/json" id="media-catalog-data" set:html={JSON.stringify(mediaCatalog)} />
<script type="application/json" id="media-catalog-config" set:html={JSON.stringify(catalogConfig)} />

<script>
  import { initMediaCatalog } from '../scripts/media-catalog';

  const root = document.querySelector('.media-catalog');
  const dataEl = document.getElementById('media-catalog-data');
  const configEl = document.getElementById('media-catalog-config');

  if (root && dataEl && configEl) {
    try {
      const entries = JSON.parse(dataEl.textContent ?? '[]');
      const config = JSON.parse(configEl.textContent ?? '{}');
      initMediaCatalog(root as HTMLElement, entries, config);
    } catch {
      /* keep SSR grid */
    }
  }
</script>

<style>
  .media-format-chip {
    border-radius: 9999px;
    border: 1px solid #e5e7eb;
    background: #fff;
    padding: 0.4rem 0.85rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-ink, #373737);
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .media-format-chip:hover {
    border-color: var(--color-primary-dark, #ff6e42);
  }

  .media-format-chip--active {
    border-color: var(--color-primary-dark, #ff6e42);
    background: var(--color-brand-light, #f5ebe9);
    color: var(--color-accent-on-light, #a83228);
  }

  .media-catalog-select {
    width: 100%;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    background: #fff;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: var(--color-ink, #373737);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .media-catalog-select:focus {
    border-color: var(--color-primary-dark, #ff6e42);
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 110, 66, 0.2);
  }

  .media-catalog-tag {
    display: inline-flex;
    border-radius: 9999px;
    padding: 0.125rem 0.5rem;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .media-catalog-tag--product {
    background: var(--color-brand-light, #f5ebe9);
    color: var(--color-accent-on-light, #a83228);
  }

  .media-catalog-tag--lang {
    background: #f3f4f6;
    color: var(--color-muted, #5c5c5c);
  }

  .media-catalog-tag--app {
    background: #eef2ff;
    color: #4338ca;
  }

  .media-catalog-tag--sample {
    background: #fef3c7;
    color: #92400e;
  }
</style>
