---
import ProductSlideshow from '../ProductSlideshow.astro';

interface Props {
  images: string[];
  alt: string;
  videoEmbedUrl?: string;
}

const { images, alt, videoEmbedUrl } = Astro.props;
---

<div class="product-hero-carousel mx-auto max-w-2xl">
  <ProductSlideshow images={images} alt={alt} />
  {
    videoEmbedUrl && (
      <div class="product-hero-video mt-6 aspect-video overflow-hidden rounded-xl bg-gray-100">
        <!-- TODO: replace with hero video when new footage is ready -->
        <iframe
          src={videoEmbedUrl}
          title={`${alt} demo video`}
          class="h-full w-full"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      </div>
    )
  }
</div>
