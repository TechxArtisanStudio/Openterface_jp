---
import { docsPath, siteConfig } from '../config/site';
import { ui } from '../i18n/ui';
import Logo from './Logo.astro';
import FooterNewsletter from './FooterNewsletter.astro';

const f = ui.siteFooter;
---

<footer class="border-t border-gray-200 bg-surface">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
      <div>
        <Logo variant="default" class="h-7" />
        <p class="mt-3 text-sm text-muted">{f.tagline}</p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-ink">{f.productsHeading}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/keymod/" class="text-muted hover:text-primary-dark">{f.keymodSeries}</a></li>
          <li><a href="/kvmgo/" class="text-muted hover:text-primary-dark">{f.kvmGoSeries}</a></li>
          <li><a href="/minikvm/" class="text-muted hover:text-primary-dark">{f.miniKvm}</a></li>
          <li><a href="/kvmext/" class="text-muted hover:text-primary-dark">KVM Extension</a></li>
          <li><a href="/accessories/" class="text-muted hover:text-primary-dark">{f.accessories}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-ink">{f.resourcesHeading}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/media/" class="text-muted hover:text-primary-dark">{f.videos}</a></li>
          <li><a href={docsPath('/faq/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">{f.faqs}</a></li>
          <li><a href="/apps/" class="text-muted hover:text-primary-dark">{f.apps}</a></li>
          <li><a href={docsPath('/support/')} class="text-muted hover:text-primary-dark" target="_blank" rel="noopener">{f.support}</a></li>
        </ul>
      </div>
    </div>

    <FooterNewsletter
      title={f.newsletterTitle}
      description={f.newsletterDescription}
      submitLabel={f.newsletterSubmit}
      namePlaceholder={f.newsletterNamePlaceholder}
      emailPlaceholder={f.newsletterEmailPlaceholder}
      footnote={f.newsletterFootnote}
    />

    <div class="mt-8 border-t border-gray-200 pt-6 text-center text-xs text-muted">
      <p>© {new Date().getFullYear()} {f.copyright}</p>
      <p class="mt-1">
        <a href={docsPath('/policy/privacy/')} class="hover:text-primary-dark" target="_blank" rel="noopener">{f.privacy}</a>
        ·
        <a href={docsPath('/policy/terms-of-service/')} class="hover:text-primary-dark" target="_blank" rel="noopener">{f.terms}</a>
        {siteConfig.analytics.enabled && (
          <>
            ·
            <a href="#" id="cookie-settings" class="hover:text-primary-dark">{siteConfig.analytics.consent.cookieLabel}</a>
          </>
        )}
      </p>
    </div>
  </div>
</footer>
