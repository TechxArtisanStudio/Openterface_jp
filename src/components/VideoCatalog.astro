---
import { catalogVideos } from '../data/catalogVideos';
import { siteConfig } from '../config/site';
import { getVideosStrings } from '../i18n/videos';
import {
  KNOWN_PRODUCTS,
  LANGUAGE_DISPLAY_NAMES,
  PRODUCT_DISPLAY_NAMES,
  productDisplayName,
  languageDisplayName,
} from '../lib/youtube';

const strings = getVideosStrings(siteConfig.locale);
const locale = siteConfig.locale;

const languages = new Set(catalogVideos.map((v) => v.language).filter(Boolean));
const products = new Set(catalogVideos.map((v) => v.product).filter(Boolean));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: strings.title,
  numberOfItems: catalogVideos.length,
  itemListElement: catalogVideos.slice(0, 20).map((video, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'VideoObject',
      name: video.title,
      url: video.url,
      thumbnailUrl: video.thumbnail,
      uploadDate: video.date || undefined,
      author: { '@type': 'Person', name: video.author },
    },
  })),
};

const catalogConfig = {
  locale,
  knownProducts: [...KNOWN_PRODUCTS],
  productLabels: PRODUCT_DISPLAY_NAMES,
  languageLabels: LANGUAGE_DISPLAY_NAMES,
  viewsLabel: strings.views,
  emptyResults: strings.emptyResults,
};
---

<section class="video-catalog bg-surface pb-16 pt-10 md:pb-20 md:pt-12" aria-labelledby="video-catalog-title">
  <div class="mx-auto max-w-6xl px-4">
    <header class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-accent-on-light">YouTube</p>
      <h1 id="video-catalog-title" class="section-title mt-2">{strings.title}</h1>
      <p class="section-subtitle">{strings.subtitle}</p>
    </header>

    <div class="video-catalog-toolbar mt-8 rounded-2xl border border-gray-200 bg-white p-4 shadow-sm md:p-5">
      <div class="flex flex-wrap gap-2 md:gap-3">
        <div class="inline-flex items-baseline gap-1.5 rounded-full border border-gray-200 bg-surface px-3 py-1.5 text-sm">
          <span class="font-bold text-ink" data-stat-total>{catalogVideos.length}</span>
          <span class="text-muted">{strings.totalVideos}</span>
        </div>
        <div class="inline-flex items-baseline gap-1.5 rounded-full border border-gray-200 bg-surface px-3 py-1.5 text-sm">
          <span class="font-bold text-ink" data-stat-languages>{languages.size}</span>
          <span class="text-muted">{strings.languages}</span>
        </div>
        <div class="inline-flex items-baseline gap-1.5 rounded-full border border-gray-200 bg-surface px-3 py-1.5 text-sm">
          <span class="font-bold text-ink" data-stat-products>{products.size}</span>
          <span class="text-muted">{strings.products}</span>
        </div>
      </div>

      <div
        class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4 lg:items-end"
        role="region"
        aria-label={strings.controlsAria}
      >
        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-semibold text-ink">{strings.sortBy}</span>
          <select data-sort class="video-catalog-select">
            <option value="newest">{strings.sortNewest}</option>
            <option value="oldest">{strings.sortOldest}</option>
            <option value="views">{strings.sortMostViews}</option>
          </select>
        </label>

        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-semibold text-ink">{strings.filterProduct}</span>
          <select data-filter-product class="video-catalog-select">
            <option value="">{strings.allProducts}</option>
          </select>
        </label>

        <label class="flex flex-col gap-1.5 text-sm">
          <span class="font-semibold text-ink">{strings.filterLanguage}</span>
          <select data-filter-language class="video-catalog-select">
            <option value="">{strings.allLanguages}</option>
          </select>
        </label>

        <p class="text-sm text-muted sm:col-span-2 lg:col-span-1 lg:text-right" aria-live="polite">
          {strings.showing}
          <strong class="text-ink"><span data-results-visible>{catalogVideos.length}</span></strong>
          /
          <span data-results-total>{catalogVideos.length}</span>
        </p>
      </div>
    </div>

    <p class="video-catalog-empty mt-8 text-center text-muted" data-empty-state hidden>
      {strings.emptyResults}
    </p>

    <div
      class="video-catalog-grid mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3"
      data-video-grid
    >
      {
        catalogVideos.map((video) => (
          <article
            class="video-catalog-card group"
            data-video-id={video.videoId}
            data-date={video.date}
            data-views={video.views}
            data-product={video.product}
            data-language={video.language}
          >
            <a href={video.url} target="_blank" rel="noopener noreferrer" class="block h-full">
              <div class="video-catalog-thumb relative aspect-video overflow-hidden rounded-xl bg-gray-200 shadow-sm ring-1 ring-black/5 transition duration-300 group-hover:-translate-y-0.5 group-hover:shadow-md group-hover:ring-primary-dark/30">
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  width={480}
                  height={270}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
                <span
                  class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/0 transition group-hover:bg-black/15"
                  aria-hidden="true"
                >
                  <span
                    class="flex h-11 w-11 scale-90 items-center justify-center rounded-full bg-black/65 text-white opacity-0 shadow-lg transition group-hover:scale-100 group-hover:opacity-100"
                  >
                    <svg class="ml-0.5 h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </span>
                </span>
              </div>
              <div class="mt-3 flex flex-col gap-2">
                <h2 class="line-clamp-2 text-base font-semibold leading-snug text-ink group-hover:text-primary-dark">
                  {video.title}
                </h2>
                {
                  video.product || video.language ? (
                    <div class="flex flex-wrap gap-1.5">
                      {
                        video.product ? (
                          <span class="video-catalog-tag video-catalog-tag--product">
                            {productDisplayName(video.product)}
                          </span>
                        ) : null
                      }
                      {
                        video.language ? (
                          <span class="video-catalog-tag video-catalog-tag--lang">
                            {languageDisplayName(video.language)}
                          </span>
                        ) : null
                      }
                    </div>
                  ) : null
                }
                <div class="flex items-center gap-2">
                  {
                    video.channelAvatar ? (
                      <img
                        src={video.channelAvatar}
                        alt=""
                        width={22}
                        height={22}
                        class="h-[22px] w-[22px] shrink-0 rounded-full bg-gray-100 object-cover ring-1 ring-gray-200/80"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : null
                  }
                  <span class="min-w-0 truncate text-sm text-muted">{video.author}</span>
                </div>
                <p class="text-xs text-muted/90">
                  {video.viewsFormatted} {strings.views}
                  {video.date ? ` · ${video.date}` : ''}
                </p>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</section>

<script type="application/json" id="video-catalog-data" set:html={JSON.stringify(catalogVideos)} />
<script type="application/json" id="video-catalog-config" set:html={JSON.stringify(catalogConfig)} />

<script>
  import { initVideoCatalog } from '../scripts/video-catalog';

  const root = document.querySelector('.video-catalog');
  const dataEl = document.getElementById('video-catalog-data');
  const configEl = document.getElementById('video-catalog-config');

  if (root && dataEl && configEl) {
    try {
      const videos = JSON.parse(dataEl.textContent ?? '[]');
      const config = JSON.parse(configEl.textContent ?? '{}');
      initVideoCatalog(root as HTMLElement, videos, config);
    } catch {
      /* keep SSR grid */
    }
  }
</script>

<style>
  .video-catalog-select {
    width: 100%;
    border-radius: 0.5rem;
    border: 1px solid #e5e7eb;
    background: #fff;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: var(--color-ink, #373737);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .video-catalog-select:focus {
    border-color: var(--color-primary-dark, #ff6e42);
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 110, 66, 0.2);
  }

  .video-catalog-tag {
    display: inline-flex;
    border-radius: 9999px;
    padding: 0.125rem 0.5rem;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .video-catalog-tag--product {
    background: var(--color-brand-light, #f5ebe9);
    color: var(--color-accent-on-light, #a83228);
  }

  .video-catalog-tag--lang {
    background: #f3f4f6;
    color: var(--color-muted, #5c5c5c);
  }
</style>
