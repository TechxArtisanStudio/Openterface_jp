---
interface Props {
  images: string[];
  alt: string;
}

const { images, alt } = Astro.props;
const id = `slideshow-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="product-slideshow mx-auto max-w-2xl" data-slideshow-id={id}>
  <div class="slideshow-frame group/slideshow relative overflow-hidden rounded-xl bg-gray-100">
    {
      images.map((src, i) => (
        <img
          src={src}
          alt={`${alt} — image ${i + 1}`}
          class:list={['slideshow-image w-full object-contain', i === 0 ? 'block' : 'hidden']}
          data-index={i}
          loading={i === 0 ? 'eager' : 'lazy'}
          height="400"
        />
      ))
    }
    {
      images.length > 1 && (
        <>
          <button
            type="button"
            class="slideshow-arrow slideshow-prev"
            aria-label="Previous image"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 6l-6 6 6 6"></path>
            </svg>
          </button>
          <button
            type="button"
            class="slideshow-arrow slideshow-next"
            aria-label="Next image"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 6l6 6-6 6"></path>
            </svg>
          </button>
          <div class="absolute bottom-3 left-0 right-0 flex justify-center gap-2">
            {
              images.map((_, i) => (
                <button
                  type="button"
                  class:list={['slideshow-dot h-2 w-2 rounded-full', i === 0 ? 'is-active' : '']}
                  data-dot={i}
                  aria-label={`Image ${i + 1}`}
                />
              ))
            }
          </div>
        </>
      )
    }
  </div>
</div>

<script>
  function initSlideshows() {
    document.querySelectorAll('[data-slideshow-id]').forEach((root) => {
      if (root.dataset.initialized) return;
      root.dataset.initialized = 'true';

      const images = Array.from(root.querySelectorAll('.slideshow-image'));
      const dots = Array.from(root.querySelectorAll('.slideshow-dot'));
      const prev = root.querySelector('.slideshow-prev');
      const next = root.querySelector('.slideshow-next');
      if (images.length <= 1) return;

      let current = 0;
      let timer;

      function show(index) {
        current = index;
        images.forEach((img, i) => img.classList.toggle('hidden', i !== index));
        images.forEach((img, i) => img.classList.toggle('block', i === index));
        dots.forEach((dot, i) => {
          dot.classList.toggle('is-active', i === index);
        });
      }

      function advance(delta) {
        show((current + delta + images.length) % images.length);
      }

      prev?.addEventListener('click', () => advance(-1));
      next?.addEventListener('click', () => advance(1));
      dots.forEach((dot, i) => dot.addEventListener('click', () => show(i)));

      timer = setInterval(() => advance(1), 5000);
      root.addEventListener('mouseenter', () => clearInterval(timer));
      root.addEventListener('mouseleave', () => {
        timer = setInterval(() => advance(1), 5000);
      });
    });
  }

  initSlideshows();
  document.addEventListener('astro:page-load', initSlideshows);
</script>

<style>
  .slideshow-image {
    max-height: 400px;
  }
  .slideshow-image.hidden {
    display: none;
  }

  .slideshow-arrow {
    position: absolute;
    top: 50%;
    z-index: 1;
    display: flex;
    height: 2.25rem;
    width: 2.25rem;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 9999px;
    background: transparent;
    color: rgb(107 114 128 / 0.55);
    transform: translateY(-50%);
    transition:
      color 0.15s ease,
      background-color 0.15s ease,
      opacity 0.15s ease;
  }

  .slideshow-arrow svg {
    height: 1.125rem;
    width: 1.125rem;
    stroke-width: 1.75;
  }

  .slideshow-prev {
    left: 0.375rem;
  }

  .slideshow-next {
    right: 0.375rem;
  }

  .slideshow-arrow:hover,
  .slideshow-arrow:focus-visible {
    background-color: rgb(255 255 255 / 0.9);
    color: var(--color-primary-dark);
    outline: none;
  }

  .group\/slideshow:hover .slideshow-arrow,
  .group\/slideshow:focus-within .slideshow-arrow {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .slideshow-arrow {
      opacity: 0;
    }
  }

  @media (max-width: 767px) {
    .slideshow-arrow {
      height: 2.5rem;
      width: 2.5rem;
      opacity: 0.45;
    }

    .slideshow-arrow:active {
      opacity: 1;
      background-color: rgb(255 255 255 / 0.85);
      color: var(--color-primary-dark);
    }
  }

  .slideshow-dot {
    border: 0;
    background-color: #d1d5db;
    padding: 0;
    transition: background-color 0.15s ease;
  }

  .slideshow-dot.is-active,
  .slideshow-dot:hover {
    background-color: var(--color-primary-dark);
  }
</style>
