---
import type { HomeSlide } from '../data/homeSlides';

interface Props {
  slides: HomeSlide[];
}

const { slides } = Astro.props;
const carouselId = 'home-carousel';
---

<section class="border-b border-gray-100 bg-surface" aria-label="Featured products">
  <div class="mx-auto max-w-6xl px-4 py-6 md:min-h-[500px] md:py-12">
    <div id={carouselId} class="relative" data-autoplay="true" data-interval="6000">
      {
        slides.map((slide, index) => (
          <div
            class:list={[
              'carousel-slide flex flex-col items-center gap-5 md:grid md:grid-cols-2 md:gap-8',
              index === 0 ? 'active' : 'hidden',
            ]}
            data-slide-index={slide.id}
          >
            <div class="carousel-copy carousel-copy-heading w-full md:col-start-1 md:row-start-1 md:self-center">
              <p class="text-xs font-bold uppercase tracking-widest text-primary-dark">{slide.category}</p>
              <h1 class="mt-2 text-2xl font-bold leading-tight text-ink sm:text-3xl md:text-4xl lg:text-[2.5rem] lg:leading-none">
                {slide.headline}
              </h1>
            </div>

            <div class="carousel-image-wrap my-2 flex w-full justify-center md:col-start-2 md:row-span-3 md:row-start-1 md:my-0 md:self-center">
              <img
                src={slide.image}
                alt={slide.imageAlt}
                class="carousel-image max-h-64 w-full rounded-xl object-contain sm:max-h-72 md:max-h-[420px]"
                data-images={JSON.stringify(slide.images ?? [slide.image])}
                loading={index === 0 ? 'eager' : 'lazy'}
                fetchpriority={index === 0 ? 'high' : 'auto'}
              />
            </div>

            <p class="carousel-copy-description mt-3 w-full text-base leading-relaxed text-muted md:col-start-1 md:row-start-2 md:mt-4 md:text-lg">
              {slide.description}
            </p>

            <div class="carousel-copy carousel-copy-actions w-full md:col-start-1 md:row-start-3">
              <div class="flex flex-col gap-2.5 sm:flex-row sm:flex-wrap sm:gap-3 md:mt-6">
                {
                  slide.primaryCta && (
                    <a
                      href={slide.primaryCta.href}
                      class="btn btn-primary w-full sm:w-auto"
                      target={slide.primaryCta.external ? '_blank' : undefined}
                      rel={slide.primaryCta.external ? 'noopener noreferrer' : undefined}
                      data-analytics-event={slide.primaryCta.analyticsEvent}
                      data-analytics-product={slide.primaryCta.analyticsProduct}
                      data-analytics-placement="home_carousel"
                    >
                      {slide.primaryCta.label}
                    </a>
                  )
                }
                {
                  slide.secondaryCta && (
                    <a
                      href={slide.secondaryCta.href}
                      class="btn btn-outline-primary w-full sm:w-auto"
                      target={slide.secondaryCta.external ? '_blank' : undefined}
                    >
                      {slide.secondaryCta.label}
                    </a>
                  )
                }
              </div>
              {
                slide.funding && (
                  <div class="mt-4 space-y-1 text-sm text-muted sm:flex sm:flex-wrap sm:items-center sm:gap-x-2 sm:space-y-0">
                    <span class="font-semibold text-primary-dark">{slide.funding.amount}</span>
                    <span class="hidden sm:inline" aria-hidden="true">·</span>
                    <span>{slide.funding.date}</span>
                    <span class="hidden sm:inline" aria-hidden="true">·</span>
                    <span>
                      <strong class="text-ink">{slide.funding.backers}</strong> Backers
                    </span>
                  </div>
                )
              }
            </div>

            <!-- Mobile progress: below CTAs on mobile -->
            <div
              class="carousel-progress-nav carousel-progress-nav--inline w-full md:hidden"
              aria-hidden={index !== 0 ? 'true' : undefined}
            >
              <div class="progress-grid grid grid-cols-2 gap-x-3 gap-y-4">
                {
                  slides.map((progressSlide, progressIndex) => (
                    <button
                      type="button"
                      class:list={[
                        'carousel-progress group flex min-h-[44px] flex-col justify-center gap-1.5 text-left',
                        progressIndex === index ? 'is-active' : '',
                      ]}
                      data-target={progressSlide.id}
                      data-index={progressIndex}
                      aria-label={`Go to slide ${progressSlide.id}: ${progressSlide.category}`}
                      {...(progressIndex === index ? { 'aria-current': 'true' } : {})}
                    >
                      <div class="progress-track h-2 w-full overflow-hidden rounded-full bg-gray-200" aria-hidden="true">
                        <div
                          class:list={[
                            'progress-fill h-full rounded-full transition-all duration-300',
                            progressIndex === index ? 'w-full progress-fill-active' : 'w-0',
                          ]}
                        />
                      </div>
                      <div>
                        <p class="progress-label-small text-[0.6875rem] font-bold uppercase leading-tight tracking-wide text-primary-dark/75 group-hover:text-primary-dark">
                          {progressSlide.progressSmall}
                        </p>
                        <p class="progress-label-large mt-0.5 line-clamp-1 text-xs leading-snug text-ink/75">
                          {progressSlide.progressLarge}
                        </p>
                      </div>
                    </button>
                  ))
                }
              </div>
            </div>
          </div>
        ))
      }

      <!-- Desktop progress nav -->
      <div class="carousel-progress-nav carousel-progress-nav--footer mt-8 hidden md:block md:mt-10">
        <div class="progress-grid grid grid-cols-4 gap-6">
          {
            slides.map((slide, index) => (
              <button
                type="button"
                class:list={[
                  'carousel-progress group flex flex-col gap-2 text-left',
                  index === 0 ? 'is-active' : '',
                ]}
                data-target={slide.id}
                data-index={index}
                aria-label={`Go to slide ${slide.id}: ${slide.category}`}
                {...(index === 0 ? { 'aria-current': 'true' } : {})}
              >
                <div class="progress-track h-2 w-full overflow-hidden rounded-full bg-gray-200" aria-hidden="true">
                  <div
                    class:list={[
                      'progress-fill h-full rounded-full transition-all duration-300',
                      index === 0 ? 'w-full progress-fill-active' : 'w-0',
                    ]}
                  />
                </div>
                <div>
                  <p class="progress-label-small text-xs font-bold uppercase leading-tight tracking-wide text-primary-dark/75 group-hover:text-primary-dark">
                    {slide.progressSmall}
                  </p>
                  <p class="progress-label-large mt-1 min-h-[2.5rem] text-sm font-semibold leading-snug text-ink/85">
                    {slide.progressLarge}
                  </p>
                </div>
              </button>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ carouselId }}>
  function initHomeCarousel(id) {
    const root = document.getElementById(id);
    if (!root || root.dataset.initialized) return;
    root.dataset.initialized = 'true';

    const slides = Array.from(root.querySelectorAll('.carousel-slide'));
    const progressBtns = Array.from(root.querySelectorAll('.carousel-progress'));
    const progressFills = Array.from(root.querySelectorAll('.progress-track .progress-fill'));
    const interval = parseInt(root.dataset.interval || '6000', 10);
    let current = 0;
    let timer;

    slides.forEach((slide) => {
      const img = slide.querySelector('.carousel-image');
      if (!img) return;
      const options = JSON.parse(img.dataset.images || '[]');
      if (options.length > 1) {
        img.src = options[Math.floor(Math.random() * options.length)];
      }
    });

    function show(index) {
      current = index;
      slides.forEach((s, i) => {
        s.classList.toggle('hidden', i !== index);
        s.classList.toggle('active', i === index);
      });
      progressFills.forEach((fill) => {
        const trackIndex = parseInt(fill.closest('.carousel-progress')?.dataset.index || '-1', 10);
        fill.classList.toggle('w-full', trackIndex === index);
        fill.classList.toggle('w-0', trackIndex !== index);
        fill.classList.toggle('progress-fill-active', trackIndex === index);
      });
      progressBtns.forEach((btn) => {
        const trackIndex = parseInt(btn.dataset.index || '-1', 10);
        btn.classList.toggle('is-active', trackIndex === index);
        if (trackIndex === index) {
          btn.setAttribute('aria-current', 'true');
        } else {
          btn.removeAttribute('aria-current');
        }
      });
    }

    function next() {
      show((current + 1) % slides.length);
    }

    function startAutoplay() {
      clearInterval(timer);
      if (root.dataset.autoplay === 'true') {
        timer = setInterval(next, interval);
      }
    }

    progressBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const trackIndex = parseInt(btn.dataset.index || '0', 10);
        show(trackIndex);
        startAutoplay();
      });
    });

    show(0);
    startAutoplay();
  }

  initHomeCarousel(carouselId);
  document.addEventListener('astro:page-load', () => initHomeCarousel(carouselId));
</script>

<style>
  .carousel-slide.hidden {
    display: none;
  }
  .carousel-slide.active {
    display: flex;
  }
  @media (min-width: 768px) {
    .carousel-slide.active {
      display: grid;
    }
  }
  .carousel-progress {
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    appearance: none;
  }
  .carousel-progress.is-active .progress-label-small {
    color: var(--color-primary-dark);
    opacity: 1;
  }
  .carousel-progress.is-active .progress-label-large {
    color: color-mix(in srgb, var(--color-ink) 92%, transparent);
  }
  @media (min-width: 768px) {
    .carousel-copy {
      animation: slideInLeft 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
  }
  @keyframes slideInLeft {
    from {
      transform: translateX(-30px);
    }
    to {
      transform: translateX(0);
    }
  }
</style>
