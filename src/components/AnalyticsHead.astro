---
import { siteConfig } from '../config/site';

const { google, ahrefs, consent } = siteConfig.analytics;
const { measurementId, linkerDomains } = google;
const { dataKey: ahrefsKey } = ahrefs;
const { storageKey } = consent;
---

<script is:inline define:vars={{ measurementId, ahrefsKey, linkerDomains, storageKey }}>
  const NON_PRODUCTION_HOSTS = /^(localhost|127\.0\.0\.1|\[::1\])$/i;
  const isProductionHost = !NON_PRODUCTION_HOSTS.test(location.hostname);

  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  window.gtag = gtag;

  if (!isProductionHost) {
    window.__openterfaceAnalytics = {
      grant() {},
      deny() {},
      showBanner() {
        const banner = document.getElementById('cookie-consent-banner');
        if (!banner) return;
        banner.hidden = false;
        banner.setAttribute('aria-hidden', 'false');
      },
    };
  } else {
  gtag('consent', 'default', {
    analytics_storage: 'denied',
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    wait_for_update: 500,
  });

  let pageViewSent = false;

  function loadAhrefs() {
    if (document.getElementById('ahrefs-analytics')) return;
    const script = document.createElement('script');
    script.id = 'ahrefs-analytics';
    script.src = 'https://analytics.ahrefs.com/analytics.js';
    script.dataset.key = ahrefsKey;
    script.async = true;
    document.head.appendChild(script);
  }

  window.__openterfaceAnalytics = {
    grant() {
      gtag('consent', 'update', { analytics_storage: 'granted' });
      if (!pageViewSent) {
        gtag('event', 'page_view');
        pageViewSent = true;
      }
      loadAhrefs();
    },
    deny() {
      gtag('consent', 'update', { analytics_storage: 'denied' });
    },
    showBanner() {
      const banner = document.getElementById('cookie-consent-banner');
      if (!banner) return;
      banner.hidden = false;
      banner.setAttribute('aria-hidden', 'false');
    },
  };

  gtag('js', new Date());
  gtag('config', measurementId, {
    send_page_view: false,
    cookie_domain: '.openterface.com',
    linker: { domains: linkerDomains },
  });

  if (location.search.includes('_gl=')) {
    const url = new URL(location.href);
    url.searchParams.delete('_gl');
    history.replaceState(null, '', url.pathname + url.search + url.hash);
  }

  const storedConsent = localStorage.getItem(storageKey);
  if (storedConsent === 'granted') {
    window.__openterfaceAnalytics.grant();
  }

  const gtagScript = document.createElement('script');
  gtagScript.async = true;
  gtagScript.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
  document.head.appendChild(gtagScript);
  }
</script>
