---
interface Props {
  message?: string;
}

const { message = 'Full documentation for this section lives on our docs site while migration is in progress.' } =
  Astro.props;

import { siteConfig } from '../config/site';
---

<div class="border-y border-brand-light bg-brand-light px-4 py-3 text-center text-sm text-ink" role="status">
  <span>{message}</span>
  <a href={siteConfig.legacyUrl} class="ml-2 font-semibold text-ink underline decoration-primary-dark underline-offset-2 hover:text-primary-dark" target="_blank" rel="noopener">
    Open documentation →
  </a>
</div>
