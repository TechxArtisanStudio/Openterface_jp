---
import SubscribeForm from './SubscribeForm.astro';
import { ui } from '../i18n/ui';

const s = ui.homeSubscribe;
---

<section
  class="border-y border-brand-light/80 bg-brand-light py-12 md:py-16 lg:py-20"
  aria-labelledby="home-subscribe-heading"
>
  <div
    class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:gap-x-16 lg:gap-y-12 lg:px-10"
  >
    <div class="min-w-0">
      <p class="text-xs font-bold uppercase tracking-widest text-accent-on-light">{s.kicker}</p>
      <h2 id="home-subscribe-heading" class="mt-2 text-2xl font-bold text-ink md:text-3xl">
        {s.heading}
      </h2>
      <p class="mt-3 text-base leading-relaxed text-muted md:text-lg">
        {s.description}
      </p>
      <ul class="mt-5 space-y-2 text-sm text-ink">
        <li class="flex gap-2">
          <span class="text-accent-on-light" aria-hidden="true">✓</span>
          {s.benefitCrowdfunding}
        </li>
        <li class="flex gap-2">
          <span class="text-accent-on-light" aria-hidden="true">✓</span>
          {s.benefitGuides}
        </li>
        <li class="flex gap-2">
          <span class="text-accent-on-light" aria-hidden="true">✓</span>
          {s.benefitUnsubscribe}
        </li>
      </ul>
    </div>

    <div
      class="subscribe-card mx-auto w-full min-w-0 max-w-md rounded-2xl border border-white/60 bg-white p-6 shadow-sm sm:p-7 lg:max-w-[22rem] lg:justify-self-center lg:p-8 xl:max-w-md"
    >
      <SubscribeForm
        formId="home-subscribe-form"
        submitLabel={s.submitLabel}
        namePlaceholder={s.namePlaceholder}
        emailPlaceholder={s.emailPlaceholder}
        footnote={s.footnote}
      />
    </div>
  </div>
</section>
