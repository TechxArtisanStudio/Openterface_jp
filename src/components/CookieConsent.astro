---
import { siteConfig } from '../config/site';

const { title, description, storageKey, acceptLabel, rejectLabel } = siteConfig.analytics.consent;
---

<div
  id="cookie-consent-banner"
  role="dialog"
  aria-labelledby="cookie-consent-title"
  aria-describedby="cookie-consent-description"
  aria-hidden="true"
  hidden
  class="fixed inset-x-0 bottom-0 z-50 border-t border-gray-200 bg-white p-4 shadow-lg"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex-1">
      <h2 id="cookie-consent-title" class="text-sm font-semibold text-ink">{title}</h2>
      <p id="cookie-consent-description" class="mt-1 text-sm text-muted">{description}</p>
    </div>
    <div class="flex shrink-0 gap-2">
      <button
        type="button"
        id="cookie-consent-reject"
        class="rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-ink hover:bg-gray-50"
      >
        {rejectLabel}
      </button>
      <button
        type="button"
        id="cookie-consent-accept"
        class="rounded-md bg-brand-dark px-4 py-2 text-sm font-semibold text-white hover:bg-brand"
      >
        {acceptLabel}
      </button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ storageKey }}>
  function hideBanner() {
    const banner = document.getElementById('cookie-consent-banner');
    if (!banner) return;
    banner.hidden = true;
    banner.setAttribute('aria-hidden', 'true');
  }

  function showBannerIfNeeded() {
    const banner = document.getElementById('cookie-consent-banner');
    if (!banner) return;
    if (!localStorage.getItem(storageKey)) {
      banner.hidden = false;
      banner.setAttribute('aria-hidden', 'false');
    }
  }

  document.getElementById('cookie-consent-accept')?.addEventListener('click', () => {
    localStorage.setItem(storageKey, 'granted');
    window.__openterfaceAnalytics?.grant();
    hideBanner();
  });

  document.getElementById('cookie-consent-reject')?.addEventListener('click', () => {
    localStorage.setItem(storageKey, 'denied');
    window.__openterfaceAnalytics?.deny();
    hideBanner();
  });

  document.getElementById('cookie-settings')?.addEventListener('click', (event) => {
    event.preventDefault();
    window.__openterfaceAnalytics?.showBanner();
  });

  showBannerIfNeeded();
</script>
