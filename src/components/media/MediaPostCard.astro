---
import { PLATFORM_DISPLAY_NAMES, productDisplayName, type MediaCatalogEntry } from '../../lib/youtube';

interface Props {
  entry: MediaCatalogEntry;
  readOriginal: string;
  platformLabels: Record<string, string>;
}

const { entry, readOriginal, platformLabels } = Astro.props;

function platformLabel(entry: MediaCatalogEntry): string {
  if (!entry.platform) return entry.format === 'testimonial' ? 'Testimonial' : 'Social';
  return platformLabels[entry.platform] ?? PLATFORM_DISPLAY_NAMES[entry.platform] ?? entry.platform;
}

const excerptClass =
  entry.format === 'testimonial' ? 'mt-2 line-clamp-3 text-sm italic text-muted' : 'mt-2 line-clamp-3 text-sm text-muted';
---

<article
  class="media-catalog-card media-catalog-card--post group"
  data-entry-id={entry.id}
  data-format={entry.format}
  data-date={entry.date}
  data-product={entry.product ?? ''}
  data-language={entry.language ?? ''}
  data-app={entry.app ?? ''}
>
  {
    entry.externalUrl ? (
      <a
        href={entry.externalUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="card block h-full hover:border-primary-dark hover:shadow-md"
      >
        {
          entry.thumbnail ? (
            <div class="media-catalog-thumb relative aspect-video overflow-hidden rounded-xl bg-gray-200 shadow-sm ring-1 ring-black/5 transition duration-300 group-hover:-translate-y-0.5 group-hover:shadow-md group-hover:ring-primary-dark/30">
              <img
                src={entry.thumbnail}
                alt={entry.title}
                width={480}
                height={270}
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <span class="pointer-events-none absolute left-2 top-2 rounded-full bg-black/60 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white">
                {platformLabel(entry)}
              </span>
            </div>
          ) : (
            <div class="flex items-start justify-between gap-2">
              <span class="text-xs font-bold uppercase tracking-wide text-muted">{platformLabel(entry)}</span>
            </div>
          )
        }
        <h3
          class:list={[
            'line-clamp-2 text-base font-semibold leading-snug text-ink group-hover:text-primary-dark',
            entry.thumbnail ? 'mt-3' : 'mt-3',
          ]}
        >
          {entry.title}
        </h3>
        <p class={excerptClass}>{entry.excerpt}</p>
        {
          entry.product ? (
            <div class="mt-3 flex flex-wrap gap-1.5">
              <span class="media-catalog-tag media-catalog-tag--product">
                {productDisplayName(entry.product)}
              </span>
            </div>
          ) : null
        }
        <div class="mt-3 flex items-center gap-2">
          {
            entry.channelAvatar ? (
              <img
                src={entry.channelAvatar}
                alt=""
                width={22}
                height={22}
                class="h-[22px] w-[22px] shrink-0 rounded-full bg-gray-100 object-cover ring-1 ring-gray-200/80"
                loading="lazy"
                decoding="async"
              />
            ) : null
          }
          <p class="min-w-0 text-sm text-muted">
            {entry.author}
            {entry.date ? ` · ${entry.date}` : ''}
          </p>
        </div>
        <p class="mt-3 text-sm font-semibold text-primary-dark">{readOriginal}</p>
      </a>
    ) : (
      <div class="card block h-full">
        {
          entry.thumbnail ? (
            <div class="media-catalog-thumb relative aspect-video overflow-hidden rounded-xl bg-gray-200 shadow-sm ring-1 ring-black/5">
              <img
                src={entry.thumbnail}
                alt={entry.title}
                width={480}
                height={270}
                class="h-full w-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <span class="pointer-events-none absolute left-2 top-2 rounded-full bg-black/60 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white">
                {platformLabel(entry)}
              </span>
            </div>
          ) : (
            <div class="flex items-start justify-between gap-2">
              <span class="text-xs font-bold uppercase tracking-wide text-muted">{platformLabel(entry)}</span>
            </div>
          )
        }
        <h3 class:list={['line-clamp-2 text-base font-semibold leading-snug text-ink', entry.thumbnail ? 'mt-3' : 'mt-3']}>
          {entry.title}
        </h3>
        <p class={excerptClass}>{entry.excerpt}</p>
        {
          entry.product ? (
            <div class="mt-3 flex flex-wrap gap-1.5">
              <span class="media-catalog-tag media-catalog-tag--product">
                {productDisplayName(entry.product)}
              </span>
            </div>
          ) : null
        }
        <div class="mt-3 flex items-center gap-2">
          {
            entry.channelAvatar ? (
              <img
                src={entry.channelAvatar}
                alt=""
                width={22}
                height={22}
                class="h-[22px] w-[22px] shrink-0 rounded-full bg-gray-100 object-cover ring-1 ring-gray-200/80"
                loading="lazy"
                decoding="async"
              />
            ) : null
          }
          <p class="min-w-0 text-sm text-muted">
            {entry.author}
            {entry.date ? ` · ${entry.date}` : ''}
          </p>
        </div>
      </div>
    )
  }
</article>
