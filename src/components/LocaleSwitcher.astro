---
import { LOCALE_LABELS, SUPPORTED_LOCALES, switchLocaleUrl, type SiteLocale } from '../lib/locale';
import { preserveQueryForLocaleSwitch } from '../lib/preserve-query';
import { siteConfig } from '../config/site';
import TranslateIcon from './TranslateIcon.astro';

interface Props {
  currentPath: string;
  currentSearch?: string;
  class?: string;
}

const { currentPath, currentSearch = '', class: className = '' } = Astro.props;
const locale = siteConfig.locale as SiteLocale;
const preservedSearch = preserveQueryForLocaleSwitch(currentSearch);
---

<details class:list={['locale-switcher relative', className]}>
  <summary
    class="site-header__icon-btn locale-switcher__toggle"
    aria-label={`Language: ${LOCALE_LABELS[locale]}`}
  >
    <TranslateIcon />
  </summary>
  <ul class="locale-switcher__menu absolute right-0 top-full z-50 mt-1 min-w-[140px] rounded-lg border border-gray-200 bg-white py-1 shadow-lg">
    {
      SUPPORTED_LOCALES.map((loc) => (
        <li>
          <a
            href={switchLocaleUrl(currentPath, loc, preservedSearch)}
            data-locale-switch
            class:list={[
              'block px-3 py-2 text-sm hover:bg-brand-light hover:text-primary-dark',
              loc === locale ? 'font-semibold text-primary-dark' : 'text-ink',
            ]}
          >
            {LOCALE_LABELS[loc]}
          </a>
        </li>
      ))
    }
  </ul>
</details>

<style>
  .locale-switcher summary::-webkit-details-marker {
    display: none;
  }
</style>

<script>
  import { applyPreservedQueryToLocaleLinks } from '../lib/preserve-query';

  applyPreservedQueryToLocaleLinks();
</script>
