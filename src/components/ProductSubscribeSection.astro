---
import SubscribeForm from './SubscribeForm.astro';
import { ui } from '../i18n/ui';

interface Props {
  productTitle: string;
  productSlug: string;
}

const { productTitle, productSlug } = Astro.props;
const s = ui.productSubscribe;
const heading = s.heading.replace('{product}', productTitle);
const formId = `product-subscribe-form-${productSlug}`;
---

<section
  class="border-y border-brand-light/80 bg-brand-light py-10 md:py-14"
  aria-labelledby={`${formId}-heading`}
>
  <div
    class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-x-12 lg:px-10"
  >
    <div class="min-w-0">
      <p class="text-xs font-bold uppercase tracking-widest text-accent-on-light">{s.kicker}</p>
      <h2 id={`${formId}-heading`} class="mt-2 text-xl font-bold text-ink md:text-2xl">
        {heading}
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-muted md:text-base">
        {s.description}
      </p>
      <ul class="mt-4 space-y-2 text-sm text-ink">
        <li class="flex gap-2">
          <span class="text-accent-on-light" aria-hidden="true">✓</span>
          {s.benefitCrowdfunding}
        </li>
        <li class="flex gap-2">
          <span class="text-accent-on-light" aria-hidden="true">✓</span>
          {s.benefitGuides}
        </li>
        <li class="flex gap-2">
          <span class="text-accent-on-light" aria-hidden="true">✓</span>
          {s.benefitUnsubscribe}
        </li>
      </ul>
    </div>

    <div
      class="subscribe-card mx-auto w-full min-w-0 max-w-md rounded-2xl border border-white/60 bg-white p-6 shadow-sm sm:p-7 lg:max-w-[22rem] lg:justify-self-center lg:p-8"
    >
      <SubscribeForm
        formId={formId}
        submitLabel={s.submitLabel}
        namePlaceholder={s.namePlaceholder}
        emailPlaceholder={s.emailPlaceholder}
        footnote={s.footnote}
        analyticsPlacement="product_page"
      />
    </div>
  </div>
</section>
