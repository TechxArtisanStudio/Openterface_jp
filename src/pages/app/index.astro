---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { appDocsLinks, appHubCards } from '../../data/apps';
---

<BaseLayout
  title="Openterface Apps"
  description="Download open-source Openterface host apps — KVM Control for Mini-KVM, KVM-GO, and uConsole; KeyCmd for phone-as-keyboard workflows."
  keywords="Openterface app, KVM software, KeyCmd, QT host app, Android KVM, open source"
  ogImageAlt="Openterface Apps — KVM Control and KeyCmd"
  canonicalPath="/app/"
>
  <DocLinkBanner variant="product" />
  <section class="product-section product-section--hero bg-gradient-to-br from-brand-light to-white">
    <div class="product-section__inner text-center">
      <h1 class="product-display-title">Openterface Apps</h1>
      <p class="product-lead mt-2">Open-source software for every product line</p>
      <p class="mx-auto mt-3 max-w-2xl text-muted">
        Choose the app that matches your hardware and host platform — or build from source on GitHub. Full installers,
        release notes, and platform guides live on docs.openterface.com.
      </p>
    </div>
  </section>

  <section class="product-section" aria-label="App product lines">
    <div class="product-section__inner">
      <div class="grid gap-6 md:grid-cols-2">
        {
          appHubCards.map((card) => (
            <a
              href={card.href}
              class="card group flex flex-col hover:border-primary-dark hover:shadow-md"
            >
              <h2 class="text-2xl font-bold text-primary-dark group-hover:text-accent-on-light">{card.title}</h2>
              <p class="mt-3 flex-1 text-muted">{card.description}</p>
              <ul class="mt-4 space-y-1 text-sm text-muted">
                {card.highlights.map((line) => (
                  <li>• {line}</li>
                ))}
              </ul>
              <span class="mt-6 text-sm font-semibold text-primary-dark">Explore {card.title} →</span>
            </a>
          ))
        }
      </div>
      <p class="mt-8 text-center">
        <a href={appDocsLinks.overview} class="btn btn-secondary" target="_blank" rel="noopener">
          Full downloads & release notes on docs →
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
