---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you requested could not be found."
  canonicalPath="/404/"
  robots="noindex, nofollow"
>
  <section class="flex min-h-[50vh] flex-col items-center justify-center px-4 py-16 text-center">
    <h1 class="text-6xl font-bold text-primary-dark">404</h1>
    <p class="mt-4 text-xl text-muted">Page not found</p>
    <a href="/" class="btn btn-primary mt-8">Back to Home</a>
  </section>
</BaseLayout>
