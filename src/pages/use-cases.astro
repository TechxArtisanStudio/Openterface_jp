---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { siteConfig } from '../config/site';
import { getUseCasesStrings } from '../i18n/use-cases';
import { pageOgImages } from '../lib/seo';

const strings = getUseCasesStrings(siteConfig.locale);
---

<BaseLayout
  title={strings.title}
  description={strings.description}
  ogImage={pageOgImages.useCases}
  ogImageAlt={strings.ogImageAlt}
  canonicalPath="/use-cases/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">{strings.title}</h1>
      <p class="mt-4 text-lg text-muted">{strings.intro}</p>
      <ul class="mt-8 space-y-4">
        {strings.items.map((item) => (
          <li class="card">{item}</li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
