---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="活用事例"
  description="Openterface KVM-over-USB 製品の実際の活用事例。"
  canonicalPath="/use-cases/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">活用事例</h1>
      <p class="mt-4 text-lg text-muted">
        Openterfaceツールは、専用のモニターやキーボードなしでヘッドレスまたはアクセスしにくいコンピュータを制御する必要があるときに真価を発揮します。
      </p>
      <ul class="mt-8 space-y-4">
        {
          [
            'データセンターやコロケーションの巡回',
            'ホームラボやNASの管理',
            '組込みデバイスやSBCの立ち上げ',
            'キオスク端末やデジタルサイネージのメンテナンス',
            '現場ITおよびコンサルティング業務',
          ].map((item) => (
            <li class="card">{item}</li>
          ))
        }
      </ul>
      <a href={legacyPath('/use-cases/')} class="btn btn-secondary mt-8" target="_blank" rel="noopener">
        すべての活用事例ギャラリーを表示 →
      </a>
    </div>
  </section>
</BaseLayout>
