---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { legacyPath } from '../../config/site';
---

<BaseLayout
  title="Openterfaceについて"
  description="Openterfaceについて — TechxArtisanによって構築されたオープンソースのKVM-over-USBソリューションを学びましょう。"
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Openterfaceについて</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Openterfaceは、ITプロフェッショナル、開発者、メイカー向けに、超コンパクトでオープンソースのKVM-over-USBツールを構築しています。
        クラウドファンディングで成功を収めたMini-KVMから、キーホルダーサイズのKVM-GO、プログラマブルなKeyModシリーズまで、私たちの使命は、かさばる機材や複雑なネットワークなしでヘッドレスコンピュータの制御を簡素化することです。
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={legacyPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          会社概要の全文 →
        </a>
        <a href={legacyPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          コンプライアンス →
        </a>
        <a href={legacyPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          コミュニティ →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
