---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { appDocsLinks, kvmFeatures, kvmPlatforms } from '../../data/apps';
---

<BaseLayout
  title="KVM Control Apps"
  description="Download Openterface KVM host apps for Windows, macOS, Linux, and Android. Control Mini-KVM, KVM-GO, and uConsole KVM Extension from your laptop or phone."
  keywords="KVM app, Openterface QT, macOS KVM, Windows KVM, Linux KVM, Android KVM, open source"
  ogImageAlt="Openterface KVM Control apps for all platforms"
  canonicalPath="/kvm/"
>
  <DocLinkBanner variant="product" />
  <section class="product-section product-section--hero bg-gradient-to-br from-brand-light to-white">
    <div class="product-section__inner text-center">
      <p class="mb-3">
        <a href="/apps/" class="text-sm font-semibold text-primary-dark hover:underline">← All apps</a>
      </p>
      <h1 class="product-display-title">KVM Control</h1>
      <p class="product-lead mt-2">Host apps for Mini-KVM, KVM-GO & uConsole KVM Extension</p>
      <p class="mx-auto mt-3 max-w-2xl text-muted">
        Control headless targets from your laptop or phone — keyboard, video, and mouse pass-through over USB with
        BIOS-level access and no software on the target device.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href={appDocsLinks.overview} class="btn btn-primary" target="_blank" rel="noopener">
          Download on docs
        </a>
        <a href={appDocsLinks.updates} class="btn btn-secondary" target="_blank" rel="noopener">
          App updates →
        </a>
      </div>
    </div>
  </section>

  <section class="product-section bg-surface" aria-label="KVM app features">
    <div class="product-section__inner">
      <h2 class="section-title text-center">What you get</h2>
      <ul class="mx-auto mt-6 grid max-w-3xl gap-3">
        {
          kvmFeatures.map((feature) => (
            <li class="flex gap-3 rounded-lg bg-white p-4 shadow-sm">
              <span class="text-primary-dark" aria-hidden="true">
                ✓
              </span>
              <span>{feature}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="product-section" aria-label="Platform downloads">
    <div class="product-section__inner">
      <h2 class="section-title text-center">Choose your platform</h2>
      <p class="section-subtitle mx-auto max-w-2xl text-center">
        Installers, portable builds, and GitHub sources for each OS — maintained on docs.openterface.com.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          kvmPlatforms.map((platform) => (
            <article class="card">
              <h3 class="text-lg font-semibold text-primary-dark">{platform.name}</h3>
              <p class="mt-2 text-sm text-muted">{platform.description}</p>
              <a
                href={platform.docsHref}
                class="mt-4 inline-block text-sm font-semibold text-primary-dark hover:underline"
                target="_blank"
                rel="noopener"
              >
                {platform.downloadLabel} →
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
