---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { appDocsLinks, keycmdHardware, keycmdModes } from '../../data/apps';
---

<BaseLayout
  title="KeyCmd App"
  description="KeyCmd turns your phone or tablet into a keyboard, trackpad, and gamepad for any computer. Android beta available — works with KeyMod, Mini-KVM, and KVM-GO."
  keywords="KeyCmd, phone keyboard, HID app, Bluetooth keyboard, gamepad app, Shortcut Hub, Openterface"
  ogImageAlt="KeyCmd — Openterface phone-as-keyboard app"
  canonicalPath="/keycmd/"
>
  <DocLinkBanner variant="product" />
  <section class="product-section product-section--hero bg-gradient-to-br from-brand-light to-white">
    <div class="product-section__inner text-center">
      <p class="mb-3">
        <a href="/app/" class="text-sm font-semibold text-primary-dark hover:underline">← All apps</a>
      </p>
      <h1 class="product-display-title">KeyCmd</h1>
      <p class="product-lead mt-2">Your phone as keyboard, trackpad & gamepad</p>
      <p class="mx-auto mt-3 max-w-2xl text-muted">
        Send keystrokes, mouse movements, and gamepad inputs to the target over USB or Bluetooth LE — with KeyMod
        hardware, Mini-KVM, or KVM-GO. Open-source Android & iPadOS beta; desktop expansion coming.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href={appDocsLinks.keycmdApk}
          class="btn btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          Download Android beta APK
        </a>
        <a href={appDocsLinks.overview} class="btn btn-secondary" target="_blank" rel="noopener">
          Docs & iPadOS info →
        </a>
      </div>
      <p class="mx-auto mt-4 max-w-xl text-sm text-muted">
        Beta notice: KeyCmd for Android is in active development. Source will be published after crowdfunding.
      </p>
    </div>
  </section>

  <section class="product-section bg-surface" aria-label="KeyCmd app modes">
    <div class="product-section__inner">
      <h2 class="section-title text-center">Five ways to control</h2>
      <p class="section-subtitle mx-auto max-w-2xl text-center">
        One app — profiles, macros, and Shortcut Hub for creative and dev workflows.
      </p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          keycmdModes.map((mode) => (
            <div class="card">
              <h3 class="text-lg font-semibold text-primary-dark">{mode.title}</h3>
              <p class="mt-2 text-sm text-muted">{mode.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="product-section" aria-label="Compatible hardware">
    <div class="product-section__inner">
      <h2 class="section-title text-center">Works with Openterface hardware</h2>
      <p class="section-subtitle mx-auto max-w-2xl text-center">
        KeyCmd pairs with our HID-capable products — KeyMod is the primary phone-as-keyboard experience.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {
          keycmdHardware.map((product) => (
            <a href={product.href} class="btn btn-secondary">
              {product.name} →
            </a>
          ))
        }
      </div>
      <p class="mt-6 text-center text-sm text-muted">
        <a href={appDocsLinks.keycmdFaq} class="font-semibold text-primary-dark hover:underline" target="_blank" rel="noopener">
          KeyCmd FAQ on docs →
        </a>
        {' '}
        (expanded FAQ hub coming soon)
      </p>
    </div>
  </section>
</BaseLayout>
