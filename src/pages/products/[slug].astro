---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductJsonLd from '../../components/ProductJsonLd.astro';
import ProductLanding from '../../layouts/ProductLanding.astro';
import { siteConfig } from '../../config/site';
import { products, productSlugs } from '../../data/products';

export function getStaticPaths() {
  return productSlugs
    .filter(
      (slug) =>
        slug !== 'minikvm' &&
        slug !== 'kvm-go' &&
        slug !== 'keymod' &&
        slug !== 'uconsole-kvm-extension' &&
        slug !== 'accessories',
    )
    .map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const product = products[slug!];

if (!product) {
  return Astro.redirect('/404');
}

const canonicalPath = `/products/${slug}/`;
const productUrl = new URL(canonicalPath, siteConfig.url).href;
---

<BaseLayout
  title={product.title}
  description={product.seoDescription}
  keywords={product.keywords}
  ogImage={product.heroImage}
  ogImageAlt={`${product.title} — ${product.slogan}`}
  ogType="product"
  canonicalPath={canonicalPath}
>
  <ProductJsonLd slot="head" product={product} url={productUrl} />
  <ProductLanding product={product} />
</BaseLayout>
