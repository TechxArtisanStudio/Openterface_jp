---
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaCatalog from '../components/MediaCatalog.astro';
import { siteConfig } from '../config/site';
import { getMediaStrings } from '../i18n/media';
import { pageOgImages } from '../lib/seo';

const strings = getMediaStrings(siteConfig.locale);
---

<BaseLayout
  title={strings.title}
  description={strings.subtitle}
  ogImage={pageOgImages.videos}
  ogImageAlt="Openterface community media — reviews, demos, and social posts"
  canonicalPath="/videos/"
>
  <MediaCatalog />
</BaseLayout>
