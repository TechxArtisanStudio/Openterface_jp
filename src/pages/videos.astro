---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="ビデオ"
  description="YouTubeでのOpenterface製品のデモ、チュートリアル、レビュー。"
  canonicalPath="/videos/"
>
  <DocLinkBanner message="ビデオパイプラインを移植するまで、フィルタリング可能なYouTubeビデオグリッドは旧サイトにあります。" />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">ビデオ</h1>
      <p class="mt-4 text-lg text-muted">
        Openterface KVMおよびKeyMod製品の製品デモ、セットアップガイド、コミュニティレビューをご覧ください。
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        すべてのビデオを閲覧 →
      </a>
    </div>
  </section>
</BaseLayout>
