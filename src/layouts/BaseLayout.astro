---
import '../styles/global.css';
import AnalyticsHead from '../components/AnalyticsHead.astro';
import AnalyticsEvents from '../components/AnalyticsEvents.astro';
import CookieConsent from '../components/CookieConsent.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../config/site';
import { getHreflangAlternates, getXDefaultUrl } from '../data/hreflang-manifest';
import { buildPageTitle, getOgImageDimensions, getOgLocale, getOgLocaleAlternates, TWITTER_SITE } from '../lib/seo';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'product';
  canonicalPath?: string;
  robots?: string;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  keywords,
  ogImage = siteConfig.ogImage,
  ogImageAlt,
  ogType = 'website',
  canonicalPath = Astro.url.pathname,
  robots = 'index, follow',
} = Astro.props;

const pageTitle = buildPageTitle(title, siteConfig.name);
const canonical = new URL(canonicalPath, siteConfig.url).href;
const hreflangAlternates = getHreflangAlternates(canonicalPath);
const xDefaultHref = getXDefaultUrl(canonicalPath);
const ogLocale = getOgLocale(siteConfig.locale);
const ogLocaleAlternates = hreflangAlternates.length > 0 ? getOgLocaleAlternates(siteConfig.locale) : [];
const resolvedOgImageAlt = ogImageAlt ?? description;
const ogImageDimensions = getOgImageDimensions(ogImage);
---

<!doctype html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="Openterface" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="shortcut icon" type="image/png" href="/images/favicon.png" />
    <link rel="apple-touch-icon" href="/images/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    {hreflangAlternates.map(({ lang, href }) => (
      <link rel="alternate" hreflang={lang} href={href} />
    ))}
    {xDefaultHref && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    {ogImageDimensions && (
      <>
        <meta property="og:image:width" content={String(ogImageDimensions.width)} />
        <meta property="og:image:height" content={String(ogImageDimensions.height)} />
      </>
    )}
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((locale) => (
      <meta property="og:locale:alternate" content={locale} />
    ))}
    <meta property="og:site_name" content={siteConfig.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_SITE} />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={resolvedOgImageAlt} />
    <slot name="head" />
    {siteConfig.analytics.enabled && <AnalyticsHead />}
  </head>
  <body class="flex min-h-screen flex-col">
    <SiteHeader />
    <main class="flex-1">
      <slot />
    </main>
    <SiteFooter />
    {siteConfig.analytics.enabled && <CookieConsent />}
    {siteConfig.analytics.enabled && <AnalyticsEvents />}
  </body>
</html>
