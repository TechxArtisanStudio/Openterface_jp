---
import DocLinkBanner from '../components/DocLinkBanner.astro';
import ProductSlideshow from '../components/ProductSlideshow.astro';
import type { Product } from '../data/products';
import { siteConfig } from '../config/site';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article>
  <section class="bg-gradient-to-br from-brand-light to-white py-12 md:py-16">
    <div class="mx-auto max-w-6xl px-4">
      <ProductSlideshow images={product.heroImages} alt={product.title} />
      <div class="mt-8 text-center">
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{product.title}</h1>
        <p class="mt-2 text-xl font-semibold text-primary-dark">{product.slogan}</p>
        <p class="mt-1 text-muted">{product.subtitle}</p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
          <a
            href={product.buyHref}
            class="btn btn-primary"
            target={product.buyHref.startsWith('http') ? '_blank' : undefined}
            rel={product.buyHref.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {product.buyLabel}
          </a>
          <a href={siteConfig.links.appOverview} class="btn btn-secondary" target="_blank" rel="noopener">
            アプリをダウンロード
          </a>
        </div>
        {
          product.funding && (
            <div class="mt-4 flex flex-wrap items-center justify-center gap-2 text-sm text-muted">
              <span class="font-semibold text-primary-dark">{product.funding.amount}</span>
              <span>{product.funding.date}</span>
              <span>|</span>
              <span>
                <strong>{product.funding.backers}</strong> 人の支援者
              </span>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <DocLinkBanner message="詳細な仕様、セットアップガイド、FAQは、移行が完了するまでドキュメントサイトにあります。" />

  <section class="py-12">
    <div class="mx-auto max-w-6xl px-4">
      <p class="mx-auto max-w-3xl text-center text-lg leading-relaxed text-muted">{product.description}</p>
    </div>
  </section>

  <section class="bg-surface py-12">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="section-title text-center">課題</h2>
      <ul class="mx-auto mt-6 grid max-w-3xl gap-3">
        {
          product.painPoints.map((point) => (
            <li class="flex gap-3 rounded-lg bg-white p-4 shadow-sm">
              <span class="text-primary-dark" aria-hidden="true">✕</span>
              <span>{point}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="py-12">
    <div class="mx-auto max-w-6xl px-4">
      <h2 class="section-title text-center">解決策</h2>
      <ul class="mx-auto mt-6 grid max-w-3xl gap-3">
        {
          product.solutions.map((point) => (
            <li class="flex gap-3 rounded-lg border border-primary-dark/20 bg-brand-light/30 p-4">
              <span class="text-primary-dark" aria-hidden="true">✓</span>
              <span class="font-medium">{point}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {
    product.hwFeatures.length > 0 && (
      <section class="bg-surface py-12 md:py-20">
        <div class="mx-auto max-w-6xl px-4">
          <h2 class="section-title text-center">ハードウェアの特長</h2>
          <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {product.hwFeatures.map((feature) => (
              <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
                <h3 class="font-bold text-ink">{feature.title}</h3>
                <p class="mt-2 text-sm text-muted leading-relaxed">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    product.swFeatures.length > 0 && (
      <section class="py-12 md:py-20">
        <div class="mx-auto max-w-6xl px-4">
          <h2 class="section-title text-center">ソフトウェア＆エコシステム</h2>
          <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {product.swFeatures.map((feature) => (
              <div class="rounded-xl border border-gray-100 bg-surface p-6 shadow-sm">
                <h3 class="font-bold text-ink">{feature.title}</h3>
                <p class="mt-2 text-sm text-muted leading-relaxed">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    product.specs.length > 0 && (
      <section class="bg-ink py-16 text-white">
        <div class="mx-auto max-w-4xl px-4">
          <h2 class="text-center text-3xl font-bold mb-10">テクニカルスペック</h2>
          <div class="grid gap-px overflow-hidden rounded-lg bg-white/10 sm:grid-cols-2">
            {product.specs.map((spec) => (
              <div class="bg-ink p-6">
                <dt class="text-sm font-medium text-white/60">{spec.label}</dt>
                <dd class="mt-1 text-lg font-semibold">{spec.value}</dd>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4 text-center">
      <h2 class="section-title">リソース</h2>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        {
          product.docLinks.map((link) => (
            <a
              href={link.href}
              class="btn btn-secondary"
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </section>
</article>
